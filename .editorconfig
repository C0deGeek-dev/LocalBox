# EditorConfig — editor defaults for the Rust workspace and its JSON/Markdown
# files. Files are UTF-8 without BOM.
# end_of_line is intentionally unset: existing files mix line endings and a
# mass reformat is not worth the churn.
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_style = space
indent_size = 4

[*.{json,yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.md]
# Markdown uses two trailing spaces for hard line breaks.
trim_trailing_whitespace = false
