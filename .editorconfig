# EditorConfig — editor defaults for the PowerShell launcher, Python proxy,
# and C# TUI. Files are UTF-8 without BOM (a pre-commit hook strips BOMs).
# end_of_line is intentionally unset: existing files mix line endings and a
# mass reformat is not worth the churn.
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[*.cs]
indent_style = space
indent_size = 4

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
# Markdown uses two trailing spaces for hard line breaks.
trim_trailing_whitespace = false
